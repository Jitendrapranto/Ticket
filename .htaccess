<IfModule mod_rewrite.c>
    Options -MultiViews -Indexes
    RewriteEngine On

    # Route all requests through the public folder
    RewriteRule ^$ public/ [L]
    RewriteRule ((?s).*) public/$1 [L]
</IfModule>

# Block access to sensitive files
<FilesMatch "^(\.env|composer\.json|composer\.lock|package\.json|package-lock\.json|artisan|phpunit\.xml)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Block access to hidden directories
<IfModule mod_rewrite.c>
    RewriteCond %{REQUEST_URI} ^/(\.git|\.env)
    RewriteRule .* - [F,L]
</IfModule>
